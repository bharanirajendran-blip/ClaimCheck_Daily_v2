# ============================================================
# ClaimCheck Daily — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# Anthropic (Claude Researcher)
# ----------------------------------------------------------
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Model used by the Researcher agent (optional override)
# Defaults to claude-opus-4-5-20251101; use sonnet for lower cost
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ----------------------------------------------------------
# OpenAI (GPT Director)
# ----------------------------------------------------------
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model used by the Director agent (optional override)
# OPENAI_MODEL=gpt-4o

# ----------------------------------------------------------
# GitHub (optional — for Actions authentication / Git push)
# ----------------------------------------------------------
# Set automatically by GitHub Actions via secrets.GITHUB_TOKEN
# Only needed for local publishing via git push
# GITHUB_TOKEN=ghp_...

# ----------------------------------------------------------
# Pipeline tuning (all optional)
# ----------------------------------------------------------
# LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
# MAX_CLAIMS_PER_DAY=5
# RESEARCH_WORKERS=3
# USE_EXTENDED_THINKING=true
